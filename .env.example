# Coding UI configuration. Copy to `.env` and edit.
# These defaults match the local gateway this project was built against.

# Anthropic-compatible gateway that serves the model. Claude Code sends
# POST /v1/messages here. No bridge (claude-code-router/LiteLLM) is needed
# because this gateway already speaks the Anthropic Messages API.
ANTHROPIC_BASE_URL=http://127.0.0.1:11434

# Model name passed in the `model` field.
ANTHROPIC_MODEL=glm-5.2:cloud

# Background "haiku" calls (summarization, titles). Must also resolve on the
# gateway, otherwise Claude Code background tasks will fail.
ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-5.2:cloud

# Models offered in the UI's model dropdown. The list is fetched LIVE from
# Ollama's /api/tags (see OLLAMA_BASE_URL), so it reflects whatever models are
# actually installed. This comma-separated list is only the FALLBACK used when
# Ollama is unreachable, and always includes ANTHROPIC_MODEL. The UI also has a
# "custom…" entry to type any name. Each chat session runs under the model
# chosen at start; switching a running session's model restarts it with
# --resume (transcript kept).
AVAILABLE_MODELS=glm-5.2:cloud,minimax-m3:cloud,kimi-k2.7-code:cloud,deepseek-v3.2:cloud,deepseek-v4-pro:cloud,gpt-oss:120b:cloud,gpt-oss:20b:cloud,gemma4:31b-cloud

# Base URL for the Ollama model catalog (GET /api/tags). Defaults to
# ANTHROPIC_BASE_URL since the gateway and Ollama usually share one host; set
# this only if your Ollama instance lives elsewhere.
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# Auth token sent as `Authorization: Bearer <token>`. The local gateway ignores it.
ANTHROPIC_AUTH_TOKEN=dummy

# Trim beta headers a non-Anthropic backend may reject.
CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1

# Web server port.
PORT=3001

# Root directory for per-session working dirs. The UI creates/picks dirs under here.
WORKSPACE_ROOT=/data/coding-ui/workspace

# Run the headless Claude subprocess with --dangerously-skip-permissions so it
# can Read/Write/Edit/Bash without interactive prompts (which stream-json print
# mode cannot answer). Only safe on a local/sandbox machine. Set to 0 to instead
# restrict with an allowedTools allowlist (see server/claude-args.js).
SKIP_PERMISSIONS=1

# Tools the spawned Claude may use without a permission prompt. Only consulted
# when SKIP_PERMISSIONS=0, OR when running as root (where
# --dangerously-skip-permissions is refused and this list becomes the fallback
# allowlist). Defaults to "Read Write Edit Bash Glob Grep WebFetch WebSearch".
# Override to add (e.g. NotebookEdit) or remove tools.
# ALLOWED_TOOLS=Read Write Edit Bash Glob Grep WebFetch WebSearch

# Web UI login password. Required to deny anonymous access. If left empty,
# the server generates a random one at startup and logs it to the console.
AUTH_PASSWORD=change-me

# Secret used to sign session cookies. Set to a long random string for
# persistent sessions across restarts; if empty, an ephemeral secret is used
# (everyone is logged out on restart).
AUTH_SECRET=