{
  "name": "coding-ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Web-based coding UI built on the Claude Code CLI, using the glm-5.2:cloud model via a local Anthropic-compatible gateway.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "node server/index.js",
    "dev:web": "vite --config web/vite.config.js",
    "build": "vite build --config web/vite.config.js",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "tui": "node tui/index.js",
    "probe": "node server/probe.js"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "blessed": "^0.1.81",
    "chalk": "^5.6.2",
    "dompurify": "^3.4.11",
    "express": "^4.19.2",
    "highlight.js": "^11.11.1",
    "jsxgraph": "^1.12.2",
    "katex": "^0.17.0",
    "marked": "^18.0.5",
    "marked-katex-extension": "^5.1.10",
    "node-pty": "^1.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.0"
  }
}
